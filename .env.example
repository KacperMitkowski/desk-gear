# Database — Neon dev branch (eu-central-1 Frankfurt)
# Konsola: https://console.neon.tech → desk-gear project → dev branch → Connection details
# Local dev: użyj Neon dev branch (separate od prod main branch)
#
# DATABASE_URL — POOLED connection (-pooler w hoście). Używane przez aplikację w runtime.
# DIRECT_DATABASE_URL — DIRECT connection (bez -pooler). Używane przez Prisma CLI (migrate / studio / db push).
# W Neon UI: toggle "Pooled connection" przełącza widok między tymi dwoma URL-ami.
# W CI / lokalnym postgres bez poolera DIRECT_DATABASE_URL można pominąć (fallback do DATABASE_URL).
DATABASE_URL=
DIRECT_DATABASE_URL=

# Auth.js v5 — używane od task #6 (Epic E3)
# Generowanie: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# (lub: openssl rand -base64 32, jeśli masz openssl w PATH)
AUTH_SECRET=

# Auth.js v5 — base URL aplikacji
# dev: http://localhost:3000
# prod: https://deskgear.vercel.app
AUTH_URL=

# Admin seed (prisma db seed) — opcjonalne. Brak = pominięcie admin upsert.
# Hasło min. 12 znaków. Używane TYLKO przez `npx prisma db seed` (lokalnie / staging bootstrap).
ADMIN_SEED_EMAIL=
ADMIN_SEED_PASSWORD=

# Node env (opcjonalne — Next.js sam ustawia development / production)
NODE_ENV=development
